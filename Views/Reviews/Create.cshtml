@using Microsoft.CodeAnalysis.CSharp.Syntax
<style>

</style>
@model ReviewViewModel;

<div class="col-md-4">
    <div id="successLabel" style="display: none; color: green;">
                ✅ Successfully inserted!
    </div>
    <div id="errorLabel" style="display: none; color: red;">
                ❌ Something went wrong please check the server!
    </div>
    <div class="form-floating">
       <form asp-controller="Reviews" asp-action="Create" method="post" >
            <div asp-validation-summary="All" class="text-danger"></div>
            <div class="form-group">
                    <label asp-for="Rating" class="control-label">Rating(1-5)</label>
                    <input asp-for="Rating" class="form-input" />
                    <span asp-validation-for="Rating" class="text-danger"></span>
            </div>
                
            <div class="form-group">
                    <label asp-for="Comment" class="control-label"></label>
                    <textarea asp-for="Comment" class="form-control"></textarea>
                    <span asp-validation-for="Comment" class="text-danger"></span>
            </div>
            <div class="form-group">            
                    
                    @* <input type ='hidden' asp-for="UserId" value="@Model?.UserId"/>
                    <span asp-validation-for="UserId" class="text-danger"></span> 
                    <input type ='hidden' asp-for="Book" value="@Model?.Book"/>
                    <span asp-validation-for="Book" class="text-danger"></span>
                    *@ 
                    <input type ='hidden' asp-for="BookId"/>
                    <span asp-validation-for="BookId" class="text-danger"></span> 
                                         
            <div class="form-group">
                    <input type="submit" value="Save" class="btn btn-primary" />
            </div>
        </form>
    
    </div>
</div>

<script>
     function showSuccess() {
    const label = document.getElementById('successLabel');
    label.style.display = 'block';
    setTimeout(() => {
      label.style.display = 'none';
    }, 3000); // 3 seconds
  } 

  function showFailure() {
    const label = document.getElementById('errorLabel');
    label.style.display = 'block';
    setTimeout(() => {
      label.style.display = 'none';
    }, 3000); // 3 seconds
  } 
</script>

@if(ViewBag.Success){
    <script>
    showSuccess();
    </script>
}
@if(ViewBag.Faillure){
    <script>
    showFailure();
    </script>
}